{
  "name": "ForumReply",
  "type": "object",
  "properties": {
    "thread_id": {
      "type": "string"
    },
    "body": {
      "type": "string"
    },
    "upvotes": {
      "type": "number",
      "default": 0
    },
    "is_accepted": {
      "type": "boolean",
      "default": false
    },
    "author_name": {
      "type": "string"
    }
  },
  "required": [
    "thread_id",
    "body"
  ],
  "rls": {
    "create": {
      "created_by": "{{user.email}}"
    },
    "read": {},
    "update": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}